# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Environment files — NEVER baked into image
*.env
*.env.*

# Version control
.git
.gitignore

# Editor / OS artefacts
.vscode/
.idea/
.DS_Store
node_modules/

# Logs
*.log
*.sqlite3

# Test infrastructure — not needed in production image
tests/
.pytest_cache/
conftest.py

# Dev/benchmark scripts — not needed in production image
scripts/
scratch_migrate/

# Report JSON files generated by benchmarks/audits
*_report.json
*_evidence.json

# Seed and one-off migration scripts
seed_*.py
apply_*.py
neon_*.py
temp.py

# Backup artefacts
backups/

# Docs
docs/
