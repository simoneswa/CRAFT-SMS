# CRAFT SMS - Institutional Environment Variable Template
# Copy this to .env (Backend) or .env.local (Frontend)

# --- SUPABASE CONFIGURATION ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key # KEEP PRIVATE
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- AUTHENTICATION ---
JWT_SECRET=your-secure-jwt-secret
OTP_EXPIRY_MINUTES=10

# --- TENANT CONFIGURATION ---
NEXT_PUBLIC_ROOT_DOMAIN=craftsms.com # e.g., localhost:3000 in dev
ALLOWED_ORIGINS=https://craftsms.com,https://*.craftsms.com

# --- PRODUCTION INFRASTRUCTURE ---
API_URL=https://api.craftsms.com
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- INSTITUTIONAL MONITORING ---
SENTRY_DSN=your-sentry-dsn # Optional
LOG_LEVEL=INFO # DEBUG in dev, INFO/ERROR in prod
