rules_version = '2';

// Firebase Storage Security Rules for CRAFT SMS
// Hierarchy: schools/{school_id}/{category}/{user_id}/{filename}
// Categories: branding, avatars, payment-slips, lesson-plans, reports, archives

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasTenant(schoolId) {
      return request.auth.token.tenant == schoolId;
    }
    
    function isSuperAdmin() {
      return request.auth.token.role == 'SUPER_ADMIN';
    }
    
    function isSchoolAdmin(schoolId) {
      return hasTenant(schoolId) && request.auth.token.role == 'SCHOOL_ADMIN';
    }
    
    function isTeacher(schoolId) {
      return hasTenant(schoolId) && request.auth.token.role == 'TEACHER';
    }
    
    function isStudent(schoolId) {
      return hasTenant(schoolId) && request.auth.token.role == 'STUDENT';
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') 
             && request.resource.size <= 2 * 1024 * 1024; // 2 MB limit
    }
    
    function isValidPdf() {
      return request.resource.contentType == 'application/pdf' 
             && request.resource.size <= 3 * 1024 * 1024; // 3 MB limit
    }

    function isValidFile() {
      return isValidImage() || isValidPdf();
    }
    
    // Match the strict school-centric hierarchy
    match /schools/{schoolId}/{category}/{userId}/{filename} {
      
      // 1. Upload permissions (Write)
      allow write: if isAuthenticated() && isValidFile() && (
        isSuperAdmin() ||
        isSchoolAdmin(schoolId) ||
        isTeacher(schoolId) ||
        // Students can only upload their own files (like payment slips) to their own user directory
        (isStudent(schoolId) && isOwner(userId) && category == 'payment-slips')
      );
      
      // 2. Read permissions (Direct reads blocked for non-admins, must use signed URLs)
      // Since the architecture specifies using Signed URLs generated by the backend, 
      // we strictly lock down direct reads from the client SDK, except for Super Admins.
      // The backend will generate signed URLs for authorized users.
      allow read: if isAuthenticated() && isSuperAdmin();
    }
  }
}
