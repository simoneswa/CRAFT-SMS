generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- OPERATIONAL SPINE (The Source of Truth) ---

model EventStore {
  id          String   @id @default(uuid()) @db.Uuid
  streamId    String   @map("stream_id") @db.Uuid
  streamType  String   @map("stream_type")
  eventType   String   @map("event_type")
  data        Json
  metadata    Json     @default("{}")
  version     Int      @default(1)
  tenantId    String   @map("tenant_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  auditEntry  AuditChain?

  @@index([streamId])
  @@index([tenantId])
  @@map("event_store")
}

model AuditChain {
  id           String     @id @default(uuid()) @db.Uuid
  eventId      String     @unique @map("event_id") @db.Uuid
  hash         String     @unique
  previousHash String     @map("previous_hash")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  event        EventStore @relation(fields: [eventId], references: [id])

  @@map("audit_chain")
}

// --- PROJECTIONS (Disposable/Rebuildable) ---

model School {
  id          String   @id @db.Uuid
  name        String
  subdomain   String   @unique
  logoUrl     String?  @map("logo_url")
  branding    Json?    @default("{\"primary_color\": \"#0D9488\", \"secondary_color\": \"#111827\"}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profiles    Profile[]
  slips       Slip[]
  attendance  Attendance[]
  grades      Grade[]
  notices     Notice[]

  @@map("schools")
}

model Profile {
  id           String   @id @db.Uuid
  schoolId     String?  @map("school_id") @db.Uuid
  fullName     String?  @map("full_name")
  role         String?
  customId     String?  @unique @map("custom_id")
  avatarUrl    String?  @map("avatar_url")
  phoneNumber  String?  @map("phone_number")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school       School?  @relation(fields: [schoolId], references: [id])

  studentSlips       Slip[]            @relation("StudentSlips")
  verifiedSlips      Slip[]            @relation("VerifiedBy")
  attendance         Attendance[]
  grades             Grade[]

  @@map("profiles")
}

model Slip {
  id          String    @id @db.Uuid
  schoolId    String    @map("school_id") @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  slipNumber  String    @map("slip_number")
  amount      Decimal   @db.Decimal(12, 2)
  status      String    @default("PENDING")
  imageUrl    String?   @map("image_url")
  verifiedBy  String?   @map("verified_by") @db.Uuid
  verifiedAt  DateTime? @map("verified_at") @db.Timestamptz(6)
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  school      School   @relation(fields: [schoolId], references: [id])
  student     Profile  @relation("StudentSlips", fields: [studentId], references: [id])
  verifier    Profile? @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@map("slips")
}

model Attendance {
  id          String   @id @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  date        DateTime @db.Date
  status      String   // PRESENT, ABSENT, LATE
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school      School   @relation(fields: [schoolId], references: [id])
  student     Profile  @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
  @@map("attendance")
}

model Grade {
  id          String   @id @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  subject     String
  score       Decimal  @db.Decimal(5, 2)
  term        String   // e.g., "FIRST_TERM", "FINAL"
  year        Int
  recordedBy  String   @map("recorded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school      School   @relation(fields: [schoolId], references: [id])
  student     Profile  @relation(fields: [studentId], references: [id])

  @@map("grades")
}

model Notice {
  id          String   @id @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  title       String
  content     String
  type        String   // GLOBAL, CLASS, INDIVIDUAL
  targetId    String?  @map("target_id") @db.Uuid // profileId or null
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school      School   @relation(fields: [schoolId], references: [id])

  @@map("notices")
}
model NewsFeed {
  id          String   @id @default(uuid()) @db.Uuid
  schoolId    String?  @map("school_id") @db.Uuid
  authorId    String?  @map("author_id") @db.Uuid
  title       String
  description String?  @map("description")
  content     String   @default("")
  imageUrl    String?  @map("image_url")
  badgeColor  String?  @map("badge_color")
  icon        String?  @map("icon")
  isGlobal    Boolean  @default(false) @map("is_global")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("news_feed")
}
