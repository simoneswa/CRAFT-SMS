generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- OPERATIONAL SPINE (The Source of Truth) ---

model EventStore {
  id          String   @id @default(uuid())
  streamId    String   @map("stream_id")
  streamType  String   @map("stream_type")
  eventType   String   @map("event_type")
  data        String   // Changed from Json to String for SQLite compatibility
  metadata    String   @default("{}") // Changed from Json to String
  version     Int      @default(1)
  tenantId    String   @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")

  auditEntry  AuditChain?

  @@index([streamId])
  @@index([tenantId])
  @@map("event_store")
}

model AuditChain {
  id           String     @id @default(uuid())
  eventId      String     @unique @map("event_id")
  hash         String     @unique             // current event + previous hash
  previousHash String     @map("previous_hash")
  createdAt    DateTime   @default(now()) @map("created_at")

  event        EventStore @relation(fields: [eventId], references: [id])

  @@map("audit_chain")
}

// --- PROJECTIONS (Disposable/Rebuildable) ---

model School {
  id          String   @id
  name        String
  subdomain   String   @unique
  logoUrl     String?  @map("logo_url")
  branding    String?  @default("{\"primary_color\": \"#0D9488\", \"secondary_color\": \"#111827\"}") // Changed from Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  profiles    Profile[]
  slips       Slip[]
  
  @@map("schools")
}

model Profile {
  id           String   @id
  schoolId     String?  @map("school_id")
  fullName     String?  @map("full_name")
  role         String?
  customId     String?  @unique @map("custom_id")
  avatarUrl    String?  @map("avatar_url")
  phoneNumber  String?  @map("phone_number")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")

  school       School?  @relation(fields: [schoolId], references: [id])
  
  studentSlips       Slip[]            @relation("StudentSlips")
  verifiedSlips      Slip[]            @relation("VerifiedBy")

  @@map("profiles")
}

model Slip {
  id          String   @id
  schoolId    String   @map("school_id")
  studentId   String   @map("student_id")
  slipNumber  String   @map("slip_number")
  amount      Float    // Changed from Decimal for SQLite compatibility
  status      String   @default("PENDING")
  imageUrl    String?  @map("image_url")
  verifiedBy  String?  @map("verified_by")
  verifiedAt  DateTime? @map("verified_at")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  school      School   @relation(fields: [schoolId], references: [id])
  student     Profile  @relation("StudentSlips", fields: [studentId], references: [id])
  verifier    Profile? @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@map("slips")
}
